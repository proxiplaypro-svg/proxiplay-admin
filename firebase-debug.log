dIn();\n        allow update, delete: if hasAdminClaim();\n      }\n    }\n\n    match /users/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /users/{userId}/fcm_tokens/{tokenId} {\n      allow read: if isAdmin() || isCurrentUser(userId);\n      allow write: if isCurrentUser(userId);\n    }\n\n    match /users/{userId}/favorites/{favoriteId} {\n      allow read, write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /users/{userId}/favoris/{favoriteId} {\n      allow read, write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /users/{userId} {\n      allow read: if isAdmin() || isCurrentUser(userId);\n      allow write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /prizes/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /ff_push_notifications/{document=**} {\n      allow read: if isAdmin();\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-06T15:23:29.548447Z","metadata":{"services":["cloud.firestore"]}}
