[debug] [2026-04-06T00:35:06.707Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/proxi-play-odzp2e/rulesets {"name":"projects/proxi-play-odzp2e/rulesets/07b63c8f-9495-4040-b9bc-18084ead69c5","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return isSignedIn()\n        && request.auth.token.email != null\n        && request.auth.token.email in [\n          \"proxiplay.pro@gmail.com\"\n        ];\n    }\n\n    function hasAdminClaim() {\n      return isSignedIn()\n        && request.auth.token.admin == true;\n    }\n\n    match /admin_stats/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /enseignes/{document=**} {\n      allow read, write: if hasAdminClaim();\n    }\n\n    match /merchants/{document=**} {\n      allow read, write: if hasAdminClaim();\n    }\n\n    match /games/{gameId} {\n      allow read, write: if hasAdminClaim();\n\n      match /participants/{participantId} {\n        allow read: if isAdmin();\n        allow write: if false;\n      }\n    }\n\n    match /jeux/{gameId} {\n      allow read, write: if hasAdminClaim();\n    }\n\n    match /users/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /users/{userId}/fcm_tokens/{tokenId} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /prizes/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /ff_push_notifications/{document=**} {\n      allow read: if isAdmin();\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-06T00:35:07.559215Z","metadata":{"services":["cloud.firestore"]}}
