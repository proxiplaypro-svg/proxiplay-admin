[debug] [2026-04-07T08:39:43.692Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/proxi-play-odzp2e/rulesets {"name":"projects/proxi-play-odzp2e/rulesets/ce752305-4e94-4931-9207-70e0aa58594d","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return isSignedIn()\n        && request.auth.token.email != null\n        && request.auth.token.email in [\n          \"proxiplay.pro@gmail.com\"\n        ];\n    }\n\n    function hasAdminClaim() {\n      return isSignedIn()\n        && request.auth.token.admin == true;\n    }\n\n    function isCurrentUser(userId) {\n      return isSignedIn()\n        && request.auth.uid == userId;\n    }\n\n    function isPublicGame() {\n      return resource.data.visible_public == true\n        || resource.data.visiblePublic == true;\n    }\n\n    function isCurrentUserPrizeWinner() {\n      return isSignedIn()\n        && resource.data.winner_id != null\n        && resource.data.winner_id == /databases/$(database)/documents/users/$(request.auth.uid);\n    }\n\n    match /admin_stats/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /enseignes/{document=**} {\n      allow read: if hasAdminClaim() || isSignedIn();\n      allow write: if hasAdminClaim() || isSignedIn();\n    }\n\n    match /merchants/{document=**} {\n      allow read: if hasAdminClaim() || isSignedIn();\n      allow write: if hasAdminClaim() || isSignedIn();\n    }\n\n    match /games/{gameId} {\n      allow read: if hasAdminClaim() || isPublicGame() || isSignedIn();\n      allow write: if hasAdminClaim();\n\n      match /participants/{participantId} {\n        allow read: if isAdmin() || isSignedIn();\n        allow create: if isSignedIn();\n        allow update, delete: if hasAdminClaim();\n      }\n    }\n\n    match /jeux/{gameId} {\n      allow read: if hasAdminClaim() || isPublicGame() || isSignedIn();\n      allow write: if hasAdminClaim();\n\n      match /participants/{participantId} {\n        allow read: if isAdmin() || isSignedIn();\n        allow create: if isSignedIn();\n        allow update, delete: if hasAdminClaim();\n      }\n    }\n\n    match /users/{document=**} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    match /users/{userId}/fcm_tokens/{tokenId} {\n      allow read: if isAdmin() || isCurrentUser(userId);\n      allow write: if isCurrentUser(userId);\n    }\n\n    match /users/{userId}/favorites/{favoriteId} {\n      allow read, write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /users/{userId}/favoris/{favoriteId} {\n      allow read, write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /users/{userId}/{document=**} {\n      allow read, write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /users/{userId} {\n      allow read: if isAdmin() || isCurrentUser(userId);\n      allow write: if isAdmin() || isCurrentUser(userId);\n    }\n\n    match /favorites/{document=**} {\n      allow read, write: if isSignedIn();\n    }\n\n    match /favoris/{document=**} {\n      allow read, write: if isSignedIn();\n    }\n\n    match /prizes/{document=**} {\n      allow read: if isAdmin() || isCurrentUserPrizeWinner();\n      allow write: if false;\n    }\n\n    match /ff_push_notifications/{document=**} {\n      allow read: if isAdmin();\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-07T08:39:43.378895Z","metadata":{"services":["cloud.firestore"]}}
