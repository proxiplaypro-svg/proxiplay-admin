rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          "proxiplay.pro@gmail.com"
        ];
    }

    function hasAdminClaim() {
      return isSignedIn()
        && request.auth.token.admin == true;
    }

    function isCurrentUser(userId) {
      return isSignedIn()
        && request.auth.uid == userId;
    }

    function isPublicGame() {
      return resource.data.visible_public == true
        || resource.data.visiblePublic == true;
    }

    function isCurrentUserPrizeWinner() {
      return isSignedIn()
        && resource.data.winner_id != null
        && resource.data.winner_id == /databases/$(database)/documents/users/$(request.auth.uid);
    }

    match /admin_stats/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /enseignes/{document=**} {
      allow read: if hasAdminClaim() || isSignedIn();
      allow write: if hasAdminClaim() || isSignedIn();
    }

    match /merchants/{document=**} {
      allow read: if hasAdminClaim() || isSignedIn();
      allow write: if hasAdminClaim() || isSignedIn();
    }

    match /games/{gameId} {
      allow read: if hasAdminClaim() || isPublicGame() || isSignedIn();
      allow write: if hasAdminClaim();

      match /participants/{participantId} {
        allow read: if isAdmin() || isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if hasAdminClaim();
      }
    }

    match /jeux/{gameId} {
      allow read: if hasAdminClaim() || isPublicGame() || isSignedIn();
      allow write: if hasAdminClaim();

      match /participants/{participantId} {
        allow read: if isAdmin() || isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if hasAdminClaim();
      }
    }

    match /users/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{userId}/fcm_tokens/{tokenId} {
      allow read: if isAdmin() || isCurrentUser(userId);
      allow write: if isCurrentUser(userId);
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isAdmin() || isCurrentUser(userId);
    }

    match /users/{userId}/favoris/{favoriteId} {
      allow read, write: if isAdmin() || isCurrentUser(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isAdmin() || isCurrentUser(userId);
    }

    match /users/{userId} {
      allow read: if isAdmin() || isCurrentUser(userId);
      allow write: if isAdmin() || isCurrentUser(userId);
    }

    match /favorites/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /favoris/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /prizes/{document=**} {
      allow read: if isAdmin() || isCurrentUserPrizeWinner();
      allow write: if false;
    }

    match /ff_push_notifications/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
