rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          "proxiplay.pro@gmail.com"
        ];
    }

    function hasAdminClaim() {
      return isSignedIn()
        && request.auth.token.admin == true;
    }

    function signedInEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : null;
    }

    function ownsEnseigneById(merchantId) {
      return merchantId != null
        && signedInEmail() != null
        && exists(/databases/$(database)/documents/enseignes/$(merchantId))
        && get(/databases/$(database)/documents/enseignes/$(merchantId)).data.email == signedInEmail();
    }

    function ownsMerchantById(merchantId) {
      return merchantId != null
        && signedInEmail() != null
        && exists(/databases/$(database)/documents/merchants/$(merchantId))
        && get(/databases/$(database)/documents/merchants/$(merchantId)).data.email == signedInEmail();
    }

    function requestedGameMerchantId() {
      return request.resource.data.merchantId != null
        ? request.resource.data.merchantId
        : request.resource.data.merchant_id != null
          ? request.resource.data.merchant_id
          : resource.data.merchantId != null
            ? resource.data.merchantId
            : resource.data.merchant_id;
    }

    function canManageRequestedGameAsMerchant() {
      let merchantId = requestedGameMerchantId();
      return ownsEnseigneById(merchantId) || ownsMerchantById(merchantId);
    }

    function isCurrentUser(userId) {
      return isSignedIn()
        && request.auth.uid == userId;
    }

    function isPublicGame() {
      return resource.data.visible_public == true
        || resource.data.visiblePublic == true;
    }

    // Support collectionGroup reads used by the live app for winner-related subcollections.
    match /{path=**}/instant_winners/{winnerId} {
      allow read: if true;
      allow write: if false;
    }

    match /{path=**}/participants/{participantId} {
      allow read: if true;
    }

    match /admin_stats/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /enseignes/{document=**} {
      allow read: if hasAdminClaim() || isSignedIn();
      allow write: if hasAdminClaim() || isSignedIn();
    }

    match /merchants/{document=**} {
      allow read: if hasAdminClaim() || isSignedIn();
      allow write: if hasAdminClaim() || isSignedIn();
    }

    match /games/{gameId} {
      allow read: if hasAdminClaim() || isPublicGame() || isSignedIn();
      allow write: if hasAdminClaim() || canManageRequestedGameAsMerchant();

      match /instant_winners/{winnerId} {
        allow read: if true;
        allow write: if false;
      }

      match /participants/{participantId} {
        // Public pages still resolve winner display from participant documents.
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if hasAdminClaim();
      }
    }

    match /jeux/{gameId} {
      allow read: if hasAdminClaim() || isPublicGame() || isSignedIn();
      allow write: if hasAdminClaim() || canManageRequestedGameAsMerchant();

      match /instant_winners/{winnerId} {
        allow read: if true;
        allow write: if false;
      }

      match /participants/{participantId} {
        // Public pages still resolve winner display from participant documents.
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if hasAdminClaim();
      }
    }

    match /users/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /users/{userId}/fcm_tokens/{tokenId} {
      allow read: if isAdmin() || isCurrentUser(userId);
      allow write: if isCurrentUser(userId);
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isAdmin() || isCurrentUser(userId);
    }

    match /users/{userId}/favoris/{favoriteId} {
      allow read, write: if isAdmin() || isCurrentUser(userId);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isAdmin() || isCurrentUser(userId);
    }

    match /users/{userId} {
      // The live app also renders winners on the public home.
      // Keep nested user data protected while allowing top-level profile reads.
      allow read: if isAdmin() || isCurrentUser(userId) || true;
      allow write: if isAdmin() || isCurrentUser(userId);
    }

    match /favorites/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /favoris/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /prizes/{document=**} {
      // Public winner banners rely on reading prize documents without auth.
      allow read: if true;
      allow write: if false;
    }

    match /ff_push_notifications/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
